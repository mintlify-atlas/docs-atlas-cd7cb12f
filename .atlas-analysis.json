  "keyFeatures": [
    "Circuit breaker with closed/open/half-open state machine",
    "Token bucket rate limiting with :wait and :error strategies",
    "PCI-compliant logging with automatic sensitive data sanitization",
    "Smart retries with exponential backoff and jitter",
    "In-flight request deduplication to prevent double-clicks and race conditions",
    "Multi-adapter support: Finch (default), Req, and Tesla",
    "Comprehensive telemetry events for Prometheus, OpenTelemetry, and LiveDashboard",
    "Pre-built configuration profiles for payment processing, high-volume APIs, and microservices",
    "Test mode blocking with adapter-agnostic mock helpers",
    "Never raises exceptions — always returns result tuples"
  ],
  "publicApiSurface": [
